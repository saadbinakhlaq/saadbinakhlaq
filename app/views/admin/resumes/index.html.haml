%h1 Listing Resumes
%table#saad
  %thead
    %tr
      %th User
      %th Fields
      %th{:colspan => "3"}
  %tbody
    - @resumes.each do |resume|
      %tr
        %td= resume.user
        %td= resume.fields
        %td= link_to 'Show', resume
        %td= link_to 'Edit', edit_resume_path(resume)
        %td= link_to 'Destroy', resume, method: :delete, data: { confirm: 'Are you sure?' }
%br/
= link_to 'New Resume', new_resume_path
