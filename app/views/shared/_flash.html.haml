%section#flash
  - if notice.present?
    .alert.alert-success.alert-dismissible{ role: 'alert' }
      %button{ type: 'button', class: 'close', data: { dismiss: 'alert' } }
        %span{ 'aria-hidden' => true }
        %span.sr-only Close
      = notice.html_safe

  - if alert.present?
    .alert.alert-danger.alert-dismissible{ role: 'alert' }
      %button{ type: 'button', class: 'close', data: { dismiss: 'alert' } }
        %span{ 'aria-hidden' => true }
        %span.sr-only Close
      = alert.html_safe